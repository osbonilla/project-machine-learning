# ─────────────────────────────────────────
#  GROQ
# ─────────────────────────────────────────
GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL=llama3-70b-8192
GROQ_UTTERANCES_PER_INTENT=100    # utterances generados con GROQ por intent
OLLAMA_UTTERANCES_PER_INTENT=50   # utterances generados con Ollama por intent
OLLAMA_URL=http://localhost:11434/api/generate  # URL de Ollama local
OLLAMA_MODEL=mistral               # modelo de Ollama a usar

# ─────────────────────────────────────────
#  Modelo ML
# ─────────────────────────────────────────
MODEL_PATH=models/model01.pkl
LABEL_ENCODER_PATH=models/label_encoder.pkl
ACTIVE_MODEL=model01                 # model01 | model02

# ─────────────────────────────────────────
#  API
# ─────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true                      # false en producción

# ─────────────────────────────────────────
#  Entorno
# ─────────────────────────────────────────
ENV=development                      # development | production
LOG_LEVEL=info
