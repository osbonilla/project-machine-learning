.uv/

# ─── Jupyter ────────────────────────────
.ipynb_checkpoints/
*.ipynb~

# ─── Datos ──────────────────────────────
data/raw/*
data/interim/*
data/processed/*
!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep
!data/external/.gitkeep

# ─── Modelos serializados ───────────────
models/*.pkl
models/*.joblib
models/*.pt
models/*.bin
!models/.gitkeep

# ─── Reportes ───────────────────────────
reports/figures/*
!reports/figures/.gitkeep

