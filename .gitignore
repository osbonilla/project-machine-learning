# ─── Entorno virtual ───────────────────
.venv/
venv/

# ─── Variables de entorno ──────────────
.env
*.env

# ─── Python ────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg

# ─── uv ────────────────────────────────
